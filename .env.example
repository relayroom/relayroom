# Root env consumed by docker compose (auto-loaded from ./.env).
# Copy to .env and fill in real values for local `docker compose up`.

# better-auth signing secret for the web service.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# SMTP (optional) — leave blank to use dev fallback (invite link shown in team UI + logged to console)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE: implicit TLS. Defaults to true when SMTP_PORT=465, false otherwise. Set explicitly to override.
# SMTP_SECURE=false
