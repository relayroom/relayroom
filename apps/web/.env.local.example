HUB_API_URL=http://localhost:48801
# Browser-side SSE connection (must be reachable from the browser, not just the Next.js server)
NEXT_PUBLIC_HUB_API_URL=http://localhost:48801

# Database (shared Postgres, better-auth tables only)
DATABASE_URL=postgres://hub:hub@localhost:48802/hub

# better-auth
BETTER_AUTH_SECRET=<generate: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:48800
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:48800

# SMTP (optional) — leave blank to use dev fallback (invite link shown in UI + logged to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_SECURE: implicit TLS. Defaults to true when SMTP_PORT=465, false otherwise. Set explicitly to override.
# SMTP_SECURE=false
