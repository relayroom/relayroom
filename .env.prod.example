# RelayRoom self-host config. Copy to .env and edit. Used by docker-compose.prod.yml.

# ── required secrets (MUST set; left EMPTY on purpose) ──────────────────────
# These are intentionally empty: docker-compose.prod.yml reads them as ${VAR:?...},
# which aborts boot on an unset OR empty value. So copying this file without editing
# REFUSES to start instead of silently booting with a public, guessable secret.
# Strong DB password (no special shell chars, or quote it).
POSTGRES_PASSWORD=
# Better Auth signing secret. Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── public addresses (how users + remote agents reach this host) ────────────
# Where browsers load the dashboard. Your domain behind TLS, or http://<host-ip>:48800.
RELAYROOM_PUBLIC_WEB_URL=http://localhost:48800
# Where agents reach the MCP server. http://<host-ip>:48801, or https://hub.example.com.
RELAYROOM_PUBLIC_SERVER_BASE=http://localhost:48801

# ── version + ports (optional) ──────────────────────────────────────────────
# Pin a release instead of :latest, e.g. 0.3.0. Keeps server/web in lockstep.
RELAYROOM_VERSION=latest
RELAYROOM_WEB_PORT=48800
RELAYROOM_SERVER_PORT=48801

# ── postgres (optional; defaults shown) ─────────────────────────────────────
POSTGRES_USER=hub
POSTGRES_DB=hub

# ── SMTP for invitation emails (optional; empty = link shown in UI + logged) ─
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=
