{
  "name": "@relayroom/db",
  "version": "0.3.16",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./auth-schema": "./src/auth-schema.ts",
    "./governance": "./src/governance.ts"
  },
  "scripts": {
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "tsx -e \"import('./src/index.ts').then(async m => { const db = m.createDb(); await m.runMigrations(db); await db.$client.end(); })\""
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  },
  "private": true
}
